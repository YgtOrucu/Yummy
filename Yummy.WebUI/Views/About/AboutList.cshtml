@model List<ResultAboutDto>
@{
    ViewData["Title"] = "AboutList";
    Layout = "~/Views/AdminLayout/AdminLayout.cshtml";
}
<div class="row">
    <div class="col-12 col-md-12 col-lg-12">
        <div class="card">
            <div class="card-body">
                <div class="section-title">Hakkımda</div>
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th scope="col">Başlık</th>
                                <th scope="col">Açıklama</th>
                                <th scope="col">ImageUrl</th>
                                <th scope="col">VideoUrl</th>
                                <th scope="col">VideoCoverImage</th>
                                <th scope="col">Rezervasyon Numarası</th>
                                <th scope="col">Sil</th>
                                <th scope="col">Güncele</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td style="align-content:center">@item.Title</td>
                                    <td style="align-content:center">@(item.Description.Length < 20 ? item.Description : item.Description.Substring(0, 20) + "...")</td>
                                    <td>
                                        <img alt="default"
                                             src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/default-150x150.png" : item.ImageUrl)"
                                             style="width: 3rem;height: 3rem;border-radius: 9999px;object-fit: cover;margin-left: auto;margin-right: auto;border: 2px solid #f1f5f9;" />
                                    </td>
                                    <td style="align-content:center">@item.VideoUrl</td>
                                    <td>
                                        <img alt="default"
                                             src="@(string.IsNullOrEmpty(item.VideoCoverImageUrl) ? "/images/default-150x150.png" : item.VideoCoverImageUrl)"
                                             style="width: 3rem;height: 3rem;border-radius: 9999px;object-fit: cover;margin-left: auto;margin-right: auto;border: 2px solid #f1f5f9;" />
                                    </td>
                                    <td style="align-content:center">@item.ReservationNumber</td>
                                    <td><a asp-controller="About" asp-action="AboutDelete" asp-route-id="@item.AboutId" class="btn btn-danger btn-sm">Sil</a></td>
                                    <td><a asp-controller="About" asp-action="AboutUpdate" asp-route-id="@item.AboutId" class="btn btn-success btn-sm">Güncelle</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <a asp-controller="About" asp-action="AboutCreate" class="btn btn-primary btn-sm">Ekle</a>
                </div>
            </div>
        </div>
    </div>
</div>
