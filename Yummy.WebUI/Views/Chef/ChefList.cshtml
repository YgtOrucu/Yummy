@model List<ResultChefDto>

@{
    ViewData["Title"] = "ChefList";
    Layout = "~/Views/AdminLayout/AdminLayout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-header d-flex justify-content-between align-items-center bg-white">
                <h4 class="text-dark font-weight-bold m-0">Şef Kadromuz</h4>
                <a asp-controller="Chef" asp-action="ChefCreate" class="btn btn-primary btn-round">
                    <i class="fas fa-user-plus mr-1"></i> Yeni Şef Ekle
                </a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="pl-4">Şef</th>
                                <th>Başlık</th>
                                <th>Açıklama Özet</th>
                                <th class="text-center">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="pl-4 d-flex align-items-center">
                                        <img src="@item.ImageUrl" class="rounded-circle mr-3" width="45" height="45" style="object-fit: cover;">
                                        <span class="font-weight-bold">@item.Name</span>
                                    </td>
                                    <td><span class="badge badge-primary">@item.Title</span></td>
                                    <td class="text-muted small">@item.Description.Substring(0, Math.Min(item.Description.Length, 40))...</td>
                                    <td class="text-center">
                                        <a asp-controller="Chef" asp-action="ChefUpdate" asp-route-id="@item.ChefId" class="btn btn-sm btn-outline-info mr-1"><i class="fas fa-sync-alt"></i></a>
                                        <a asp-controller="Chef" asp-action="ChefDelete" asp-route-id="@item.ChefId" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
