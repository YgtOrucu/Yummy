@model List<ResultChefDto>

@{
    ViewData["Title"] = "ChefList";
    Layout = "~/Views/AdminLayout/AdminLayout.cshtml";
}

<div class="row">
    <div class="col-12 col-md-12 col-lg-12">
        <div class="card">
            <div class="card-body">
                <div class="section-title">Şefler</div>
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th scope="col">Adı Soyadı</th>
                                <th scope="col">Başlık</th>
                                <th scope="col">Açıklama</th>
                                <th scope="col">Resim Yolu</th>
                                <th scope="col">Sil</th>
                                <th scope="col">Güncele</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td style="align-content:center">@item.Name</td>
                                    <td style="align-content:center">@item.Title</td>
                                    <td style="align-content:center">@item.Description</td>
                                    <td>
                                        <img alt="Bakery item thumbnail"
                                             src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/default-150x150.png" : item.ImageUrl)"
                                             style="width: 3rem;height: 3rem;border-radius: 9999px;object-fit: cover;margin-left: auto;margin-right: auto;border: 2px solid #f1f5f9;" />
                                    </td>
                                    <td style="align-content:center"><a asp-controller="Chef" asp-action="ChefDelete" asp-route-id="@item.ChefId" class="btn btn-danger btn-sm">Sil</a></td>
                                    <td style="align-content:center"><a asp-controller="Chef" asp-action="ChefUpdate" asp-route-id="@item.ChefId" class="btn btn-success btn-sm">Güncelle</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    @if (Model.Count > 3)
                    {
                        <a asp-controller="Chef" asp-action="ChefCreate" class="btn btn-primary btn-sm disabled">Ekle</a>
                    }
                    else
                    {
                        <a asp-controller="Chef" asp-action="ChefCreate" class="btn btn-primary btn-sm">Ekle</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
