@model List<ResultFeatureDto>
@{
    ViewData["Title"] = "FeatureList";
    Layout = "~/Views/AdminLayout/AdminLayout.cshtml";
}
<div class="row">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-header d-flex justify-content-between align-items-center bg-white">
                <h4 class="text-dark font-weight-bold m-0"><i class="fas fa-star mr-2"></i>Öne Çıkan Özellikler</h4>
                <a asp-controller="Feature" asp-action="FeatureCreate" class="btn btn-primary btn-round">Ekle</a>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Başlık</th>
                            <th>Açıklama</th>
                            <th class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="font-weight-bold">@item.Title</td>
                                <td>@item.Description</td>
                                <td class="text-center">
                                    <a asp-controller="Feature" asp-action="FeatureUpdate" asp-route-id="@item.FeatureId" class="btn btn-sm btn-outline-success"><i class="fas fa-edit"></i></a>
                                    <a asp-controller="Feature" asp-action="FeatureDelete" asp-route-id="@item.FeatureId" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>