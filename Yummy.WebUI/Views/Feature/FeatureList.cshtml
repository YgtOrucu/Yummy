@model List<ResultFeatureDto>
@{
    ViewData["Title"] = "FeatureList";
    Layout = "~/Views/AdminLayout/AdminLayout.cshtml";
}
<div class="row">
    <div class="col-12 col-md-12 col-lg-12">
        <div class="card">
            <div class="card-body">
                <div class="section-title">Servislerimiz</div>
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th scope="col">Başlık</th>
                                <th scope="col">Açıklama</th>
                                <th scope="col">Icon</th>
                                <th scope="col">Sil</th>
                                <th scope="col">Güncele</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Title</td>
                                    <td>@(item.Description.Length < 20 ? item.Description : item.Description.Substring(0, 20) + "...")</td>
                                    <td>@item.Icon</td>
                                    <td><a asp-controller="Feature" asp-action="FeatureDelete" asp-route-id="@item.FeatureId" class="btn btn-danger btn-sm">Sil</a></td>
                                    <td><a asp-controller="Feature" asp-action="FeatureUpdate" asp-route-id="@item.FeatureId" class="btn btn-success btn-sm">Güncelle</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    @if (Model.Count > 3)
                    {
                        <a asp-controller="Feature" asp-action="FeatureCreate" class="btn btn-primary btn-sm disabled">Ekle</a>
                    }
                    else
                    {
                        <a asp-controller="Feature" asp-action="FeatureCreate" class="btn btn-primary btn-sm">Ekle</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
