@model UpdateFeatureDto
@{
    ViewData["Title"] = "FeatureUpdate";
    Layout = "~/Views/AdminLayout/AdminLayout.cshtml";
}
<div class="row">
    <div class="col-12 col-md-12 col-lg-12">
        <div class="card">
            <div class="card-body">
                <div class="section-title">Güncelleme İşlemi</div>
                <div class="table-responsive">
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                    <form asp-controller="Feature" asp-action="FeatureUpdate" method="post">
                        <input type="hidden" asp-for="FeatureId" />
                        <label asp-for="Title">Başlık</label>
                        <input type="text" class="form-control" asp-for="Title" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                        <br />
                        <label asp-for="Description">Açıklama</label>
                        <input type="text" class="form-control" asp-for="Description" />
                        <span asp-validation-for="Description" class="text-danger"></span>
                        <br />
                        <label asp-for="Icon">IconUrl</label>
                        <input type="text" class="form-control" asp-for="Icon" />
                        <br />
                        <button type="submit" class="btn btn-primary">Güncelle</button>
                        <a asp-controller="Feature" asp-action="FeatureList" class="btn btn-danger">Geri</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

