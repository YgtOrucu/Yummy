@model List<ResultGalleryDto>

@{
    ViewData["Title"] = "GalleryList";
    Layout = "~/Views/AdminLayout/AdminLayout.cshtml";
}
<div class="row">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-header d-flex justify-content-between align-items-center bg-white">
                <h4 class="text-dark font-weight-bold m-0"><i class="fas fa-images mr-2"></i>Galeri Yönetimi</h4>
                <a asp-controller="Gallery" asp-action="GalleryCreate" class="btn btn-primary btn-round">Yeni Resim Yükle</a>
            </div>
            <div class="card-body">
                <div class="row">
                    @foreach (var item in Model)
                    {
                        <div class="col-md-3 mb-4">
                            <div class="card border shadow-none mb-0">
                                <img src="@item.ImageUrl" class="card-img-top" style="height:150px; object-fit:cover;">
                                <div class="card-footer p-2 d-flex justify-content-around bg-light">
                                    <a href="@item.ImageUrl" target="_blank" class="btn btn-sm btn-info"><i class="fas fa-search-plus"></i></a>
                                    <a asp-controller="Gallery" asp-action="GalleryUpdate" asp-route-id="@item.GalleryId" class="btn btn-sm btn-success"><i class="fas fa-pencil-alt"></i></a>
                                    <a asp-controller="Gallery" asp-action="GalleryDelete" asp-route-id="@item.GalleryId" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>