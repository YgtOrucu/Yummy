@model GetHeroByIdDto
@{
    ViewData["Title"] = "HeroUpdate";
    Layout = "~/Views/AdminLayout/AdminLayout.cshtml";
}

<div class="col-12 col-md-12 col-lg-12">
    <div class="card">
        <div class="card-body">
            <div class="section-title">Güncelleme İşlemi</div>
            <div class="table-responsive">
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                <form asp-controller="Hero" asp-action="HeroUpdate" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="HeroId" />
                    <label asp-for="Title">Başlık</label>
                    <input type="text" class="form-control" asp-for="Title" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                    <br />
                    <label asp-for="SubTitle">AltBaşlık</label>
                    <input type="text" class="form-control" asp-for="SubTitle" />
                    <span asp-validation-for="SubTitle" class="text-danger"></span>
                    <br />
                    <label asp-for="Description">Açıklama</label>
                    <input type="text" class="form-control" asp-for="Description" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                    <br />
                    <label asp-for="VideoUrl">VideoUrl</label>
                    <input type="text" class="form-control" asp-for="VideoUrl" />
                    <br />
                    <label>Mevcut Resim</label>
                    <br />
                    <img src="@Model.ImageUrl" style="width:150px; height:100px; border-radius:10px; border:1px solid #ddd" />
                    <input type="hidden" asp-for="ImageUrl" /> <br/>
                    <label>Yeni Resim Seç (Opsiyonel)</label>
                    <input type="file" class="form-control" asp-for="ImageFile" />
                    <br />
                    <button type="submit" class="btn btn-primary">Güncelle</button>
                    <a asp-controller="Hero" asp-action="HeroList" class="btn btn-danger">Geri</a>
                </form>
            </div>
        </div>
    </div>
</div>

