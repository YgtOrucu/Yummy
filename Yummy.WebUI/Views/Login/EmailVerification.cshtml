@{
    Layout = null;
}

<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Yummy - Doğrulama</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#c48940",
                        "primary-dark": "#8B6B4A",
                        "background-light": "#f8f7f6",
                        "background-dark": "#1e1a14",
                        "cream-soft": "#FFF5E1",
                        "cream-warm": "#FAEBD7",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                },
            },
        }
    </script>
    <style>
        /* Yeni Palete Uygun Gradient */
        .gradient-bg {
            background: linear-gradient(135deg, #c48940 0%, #8B6B4A 100%);
        }
        /* Input focus efektini yumuşattık */
        .input-glow:focus {
            box-shadow: 0 0 15px rgba(196, 137, 64, 0.2);
        }

        input::-webkit-outer-spin-button, input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        input[type=number] {
            -moz-appearance: textfield;
        }
    </style>
</head>
<body class="font-display bg-background-light dark:bg-background-dark min-h-screen flex items-center justify-center p-4">

    <main class="relative z-10 w-full max-w-[450px] bg-white dark:bg-[#2a241c] rounded-2xl shadow-2xl overflow-hidden border border-primary/10">
        <div class="px-8 pt-10 pb-12 flex flex-col items-center">

            <div class="mb-8 flex items-center justify-center size-16 rounded-xl gradient-bg shadow-lg shadow-primary/20">
                <svg class="text-cream-soft" fill="none" height="36" viewBox="0 0 48 48" width="36" xmlns="http://www.w3.org/2000/svg">
                    <path d="M6 6H42L36 24L42 42H6L12 24L6 6Z" fill="currentColor"></path>
                </svg>
            </div>

            <h1 class="text-2xl font-bold text-gray-900 dark:text-cream-soft mb-2 text-center tracking-tight">E-posta Doğrulama</h1>
            <p class="text-gray-500 dark:text-gray-400 text-center text-sm leading-relaxed mb-10 max-w-[320px]">
                Lütfen <span class="text-primary font-semibold">@TempData["UserEmail"]</span> adresine gönderilen 6 haneli kodu giriniz.
            </p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="mb-6 w-full rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 p-4 text-sm text-red-700 dark:text-red-400">
                    <div asp-validation-summary="All" class="list-disc list-inside"></div>
                </div>
            }

            <form asp-action="EmailVerification" asp-controller="Login" method="post" id="otpForm" class="w-full">
                <div class="flex justify-between gap-2 mb-10">
                    @for (int i = 0; i < 6; i++)
                    {
                        <input class="otp-input size-12 md:size-14 text-center text-xl font-bold bg-cream-soft/30 dark:bg-background-dark/50 border-gray-200 dark:border-gray-700 border rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all text-gray-900 dark:text-white input-glow"
                               inputmode="numeric" pattern="[0-9]" maxlength="1" type="text" required />
                    }
                </div>

                <input type="hidden" name="confirmCode" id="otpCode" />

                <button type="submit" class="w-full h-14 gradient-bg text-white font-semibold text-base rounded-lg shadow-lg shadow-primary/30 hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                    Doğrula ve Devam Et
                    <span class="material-symbols-outlined text-lg">arrow_forward</span>
                </button>
            </form>

            <div class="mt-6">
                <a href="/Login/Login" class="text-sm text-primary-dark dark:text-primary hover:underline font-medium">Giriş sayfasına dön</a>
            </div>
        </div>
    </main>

    <script>
        const inputs = document.querySelectorAll(".otp-input");
        const hiddenInput = document.getElementById("otpCode");
        const form = document.getElementById("otpForm");

        inputs.forEach((input, index) => {
            input.addEventListener("input", (e) => {
                if (e.inputType === "deleteContentBackward") return;
                if (input.value && index < inputs.length - 1) {
                    inputs[index + 1].focus();
                }
            });

            input.addEventListener("keydown", (e) => {
                if (e.key === "Backspace" && !input.value && index > 0) {
                    inputs[index - 1].focus();
                }
            });
        });

        form.addEventListener("submit", (e) => {
            let code = "";
            inputs.forEach(i => code += i.value);
            hiddenInput.value = code;

            if(code.length < 6) {
                e.preventDefault();
                alert("Lütfen 6 haneli kodu tamamlayın.");
            }
        });
    </script>
</body>
</html>