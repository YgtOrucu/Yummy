@{
    Layout = null;
}

<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Yummy - Şifremi Unuttum</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#c48940",
                        "primary-dark": "#8B6B4A",
                        "background-light": "#f8f7f6",
                        "background-dark": "#1e1a14",
                        "cream-soft": "#FFF5E1",
                    },
                    fontFamily: { "display": ["Inter", "sans-serif"] },
                },
            },
        }
    </script>
    <style>
        .gradient-bg {
            background: linear-gradient(135deg, #c48940 0%, #8B6B4A 100%);
        }
    </style>
</head>
<body class="font-display bg-background-light dark:bg-background-dark min-h-screen flex items-center justify-center p-4">

    <main class="relative z-10 w-full max-w-[450px] bg-white dark:bg-[#2a241c] rounded-2xl shadow-2xl overflow-hidden border border-primary/10">
        <div class="px-8 pt-10 pb-12 flex flex-col items-center">

            <div class="mb-8 flex items-center justify-center size-16 rounded-xl gradient-bg shadow-lg shadow-primary/20">
                <span class="material-symbols-outlined text-white text-3xl">lock_reset</span>
            </div>

            <h1 class="text-2xl font-bold text-gray-900 dark:text-cream-soft mb-2 text-center tracking-tight">Şifremi Unuttum</h1>
            <p class="text-gray-500 dark:text-gray-400 text-center text-sm leading-relaxed mb-8 max-w-[320px]">
                Endişelenmeyin! Kayıtlı e-posta adresinizi girin, size şifre sıfırlama kodu gönderelim.
            </p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="mb-6 w-full rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 p-4 text-sm text-red-700 dark:text-red-400">
                    <div asp-validation-summary="All" class="list-disc list-inside"></div>
                </div>
            }

            <form asp-action="ForgotPassword" asp-controller="Login" method="post" class="w-full">
                <div class="mb-6">
                    <label class="block text-xs font-semibold text-gray-400 uppercase mb-2 ml-1">E-posta Adresi</label>
                    <input type="email" name="email" required
                           class="w-full h-12 px-4 bg-cream-soft/30 dark:bg-background-dark/50 border-gray-200 dark:border-gray-700 border rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all text-gray-900 dark:text-white"
                           placeholder="ornek@mail.com" />
                </div>

                <button type="submit" class="w-full h-14 gradient-bg text-white font-semibold text-base rounded-lg shadow-lg shadow-primary/30 hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                    Kod Gönder
                    <span class="material-symbols-outlined text-lg">send</span>
                </button>
            </form>

            <div class="mt-6">
                <a href="/Login/Login" class="text-sm text-primary-dark dark:text-primary hover:underline font-medium flex items-center gap-1">
                    <span class="material-symbols-outlined text-sm">arrow_back</span> Giriş sayfasına dön
                </a>
            </div>
        </div>
    </main>

</body>
</html>