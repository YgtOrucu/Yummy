@model LoginDto

@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Yummy - Giriş Yap</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#c48940",
                        "primary-dark": "#8B6B4A",
                        "background-light": "#f8f7f6",
                        "background-dark": "#1e1a14",
                        "cream-soft": "#FFF5E1",
                        "cream-warm": "#FAEBD7",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    }
                },
            },
        }
    </script>
    <style>
        .organic-shape {
            position: absolute;
            z-index: 0;
            filter: blur(60px);
            opacity: 0.5;
            background: #c48940;
            border-radius: 50%;
        }
        /* ASP.NET Validation Summary Stilini Temizle */
        .validation-summary-errors ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }
    </style>
</head>
<body class="font-display bg-background-light dark:bg-background-dark min-h-screen relative overflow-hidden flex flex-col">
    
    <div class="organic-shape w-[400px] h-[400px] -top-20 -left-20 bg-primary/20"></div>
    <div class="organic-shape w-[300px] h-[300px] bottom-10 right-10 bg-primary/10"></div>

    <div class="relative z-10 flex flex-col min-h-screen">
        
        <header class="flex items-center justify-between px-6 py-4 md:px-12">
            <div class="flex items-center gap-2">
                <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center text-white shadow-lg shadow-primary/20">
                    <span class="material-symbols-outlined">bakery_dining</span>
                </div>
                <h1 class="text-xl font-bold text-slate-900 dark:text-slate-100 tracking-tight">Yummy <span class="text-primary">Eats</span></h1>
            </div>
        </header>

        <main class="flex-1 flex items-center justify-center p-4">
            <div class="w-full max-w-[450px] bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl rounded-xl shadow-[0_20px_50px_rgba(196,137,64,0.15)] border border-white/20 p-8 md:p-10">
                
                <div class="text-center mb-8">
                    <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-100 mb-1">Hoş Geldiniz</h2>
                    <p class="text-slate-500 dark:text-slate-400 text-sm">Lezzet dolu dünyamıza giriş yapın</p>
                </div>

                <form asp-action="Login" asp-controller="Login" method="post" class="space-y-5">
                    
                    <div asp-validation-summary="ModelOnly" class="text-rose-500 bg-rose-50 dark:bg-rose-900/20 p-3 rounded-lg text-xs font-medium border border-rose-100 dark:border-rose-800 empty:hidden">
                    </div>

                    <div class="space-y-1.5">
                        <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 ml-1" asp-for="Email">E-posta Adresi</label>
                        <div class="relative group">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-primary transition-colors">mail</span>
                            <input asp-for="Email" class="w-full pl-12 pr-4 py-3.5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all placeholder:text-slate-400" placeholder="ornek@mail.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-[11px] text-rose-500 font-medium ml-1"></span>
                    </div>

                    <div class="space-y-1.5">
                        <div class="flex justify-between items-center ml-1">
                            <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300" asp-for="Password">Şifre</label>
                            <a class="text-xs font-semibold text-primary hover:underline" href="/Login/ForgotPassword">Şifremi Unuttum?</a>
                        </div>
                        <div class="relative group">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-primary transition-colors">lock</span>
                            <input asp-for="Password" type="password" class="w-full pl-12 pr-4 py-3.5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all placeholder:text-slate-400" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="Password" class="text-[11px] text-rose-500 font-medium ml-1"></span>
                    </div>

                    <button class="w-full bg-primary hover:bg-primary-dark text-white font-bold py-4 rounded-lg shadow-lg shadow-primary/30 transition-all active:scale-[0.98] flex items-center justify-center gap-2 group" type="submit">
                        <span>Giriş Yap</span>
                        <span class="material-symbols-outlined text-xl group-hover:translate-x-1 transition-transform">arrow_forward</span>
                    </button>
                </form>

                <div class="mt-8 pt-6 border-t border-slate-100 dark:border-slate-800 text-center">
                    <p class="text-sm text-slate-500 dark:text-slate-400">
                        Henüz hesabınız yok mu?
                        <a class="text-primary font-bold hover:underline" href="/Register/Register">Kayıt Ol</a>
                    </p>
                </div>
            </div>
        </main>
    </div>
</body>
</html>