@model GetMessageByIdDto

@{
    ViewData["Title"] = "AnswerMessageWithOpenAI";
    Layout = "~/Views/AdminLayout/AdminLayout.cshtml";
}
<div class="row">
    <div class="col-12 col-md-12 col-lg-12">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="section-title text-primary font-weight-bold mb-4" style="color: #6777ef !important;">
                    <i class="fas fa-robot mr-2"></i> Mesaj Yanıt Yönetimi
                </div>

                <form asp-controller="Message" asp-action="GenerateAIDraft" method="post" class="mb-4">
                    <input type="hidden" name="MessageId" value="@Model.MessageId" />
                    <input type="hidden" name="CustomerName" value="@Model.Name" />
                    <input type="hidden" name="CustomerSubject" value="@Model.Subject" />
                    <div class="form-group">
                        <label class="font-weight-bold text-dark">Gelen Müşteri Mesajı</label>
                        <textarea name="CustomerMessage" class="form-control bg-light" style="height:250px !important" readonly>@Model.MessageContent</textarea>
                    </div>
                    <button type="submit" class="btn btn-outline-info btn-sm rounded-pill mt-2">
                        <i class="fas fa-magic mr-1"></i> AI ile Yanıt Taslağı Hazırla
                    </button>
                </form>

                <hr />

                <form asp-controller="Message" asp-action="SendFinalMail" method="post">
                    <input type="hidden" name="MessageId" value="@Model.MessageId" />
                    <input type="hidden" name="ReceiverEmail" value="@Model.Email" />

                    <div class="form-group mt-3">
                        <label class="font-weight-bold text-dark">Gönderilecek Yanıt (Düzenlenebilir)</label>
                        <textarea name="FinalResponse" class="form-control" style="height:250px !important" placeholder="Yanıtınızı buraya yazın veya yukarıdaki AI butonunu kullanın...">@ViewBag.AnswerAI</textarea>
                    </div>

                    <div class="mt-4 text-right">
                        <button type="submit" class="btn btn-primary px-5 shadow-sm">
                            <i class="fas fa-paper-plane mr-2"></i> Mail Olarak Yolla
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>