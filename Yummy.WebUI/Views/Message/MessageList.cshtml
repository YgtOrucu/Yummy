@model List<ResultMessageDto>
@{
    ViewData["Title"] = "MessageList";
    Layout = "~/Views/AdminLayout/AdminLayout.cshtml";
}

<div class="col-12">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <h4 class="text-primary mb-0 font-weight-bold" style="color: #6777ef !important;">
                <i class="fas fa-envelope-open-text mr-2"></i> Müşteri Mesaj Yönetimi
            </h4>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="bg-light text-muted">
                        <tr>
                            <th>Ad Soyad</th>
                            <th>Email Adresi</th>
                            <th>Konu</th>
                            <th>Tarih</th>
                            <th class="text-center">Durum</th>
                            <th class="text-center">Status</th>
                            <th class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="@(item.IsRead ? "text-muted" : "font-weight-bold")" style="@(item.IsRead ? "" : "background-color: #f8f9ff;")">
                                <td class="align-middle">@item.Name</td>
                                <td class="align-middle">
                                    <span class="text-info">@item.Email</span>
                                </td>
                                <td class="align-middle">@item.Subject</td>
                                <td class="align-middle">@item.MessageDate.ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="align-middle text-center">
                                    @if (item.IsRead)
                                    {
                                        <span class="badge badge-secondary px-3 py-2">Okundu</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-success px-3 py-2 shadow-sm animate-pulse">Yeni Mesaj</span>
                                    }
                                </td>
                                <td class="align-middle text-center">@(item.Status)</td>
                                <td class="align-middle text-center">
                                    <div class="btn-group shadow-sm">
                                        <a asp-controller="Message" asp-action="AnswerMessageWithOpenAI" asp-route-id="@item.MessageId"
                                           class="btn btn-sm btn-info" title="Oku ve AI ile Yanıtla">
                                            <i class="fas fa-robot"></i>
                                        </a>
                                        <a asp-controller="Message" asp-action="MessageDelete" asp-route-id="@item.MessageId"
                                           class="btn btn-sm btn-danger" title="Sil">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .table tbody tr {
        transition: all 0.2s ease;
    }

    .table-hover tbody tr:hover {
        background-color: #f1f4f9 !important;
    }

    .animate-pulse {
        animation: pulse-green 2s infinite;
    }

    @@keyframes pulse-green {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.05);
        }

        100% {
            transform: scale(1);
        }
    }
</style>