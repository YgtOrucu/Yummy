<div class="row">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            @* Kart Başlığı ve Sağ Üst Buton *@
            <div class="card-header d-flex justify-content-between align-items-center bg-white py-3">
                <h4 class="text-primary m-0"><i class="fas fa-box mr-2"></i>Ürün Listesi</h4>
                <a asp-controller="Product" asp-action="ProductCreate" class="btn btn-primary btn-round">
                    <i class="fas fa-plus mr-1"></i> Yeni Ürün Ekle
                </a>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-vcenter mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="pl-4">Ürün Bilgisi</th>
                                <th class="pl-4">Fiyat</th>
                                <th class="pl-4">Kategori</th>
                                <th class="text-right pr-4">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="pl-4">
                                        <div class="d-flex align-items-center">
                                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/default.png" : item.ImageUrl)"
                                                 class="rounded-circle shadow-sm mr-3"
                                                 style="width: 45px; height: 45px; object-fit: cover; border: 2px solid #f1f5f9;">
                                            <div>
                                                <div class="font-weight-bold text-dark">@item.ProductName</div>
                                                <small class="text-muted">@item.Description.Substring(0, Math.Min(item.Description.Length, 30))...</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="badge badge-soft-success">@item.Price.ToString("C2")</span></td>
                                    <td><span class="badge badge-soft-info">@item.CategoryName</span></td>
                                    <td class="text-right pr-4">
                                        <a asp-controller="Product" asp-action="ProductUpdate" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-primary mr-1" title="Güncelle">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-controller="Product" asp-action="ProductDelete" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-danger" title="Sil">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

