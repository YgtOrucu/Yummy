@model List<ResultReservationDto>
@{
    ViewData["Title"] = "ReservationList";
    Layout = "~/Views/AdminLayout/AdminLayout.cshtml";
}
<div class="row">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white">
                <h4 class="text-dark font-weight-bold m-0"><i class="fas fa-calendar-check mr-2"></i>Rezervasyon Listesi</h4>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="pl-4">Müşteri / Kişi</th>
                            <th>Tarih</th>
                            <th>Mesaj</th>
                            <th class="text-center">Durum</th>
                            <th class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="pl-4">
                                    <div class="font-weight-bold">@item.Name</div>
                                    <small class="text-muted">@item.PeopleCount Kişilik</small>
                                </td>
                                <td>@item.ReservationDate.ToString("dd MMM yyyy")</td>
                                <td class="small">@item.Message</td>
                                <td class="text-center">
                                    <span class="badge badge-success px-3">Onaylı</span>
                                </td>
                                <td class="text-center">
                                    <a asp-controller="Reservation" asp-action="ReservationDelete" asp-route-id="@item.ReservationId" class="btn btn-sm btn-danger"><i class="fas fa-times"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>