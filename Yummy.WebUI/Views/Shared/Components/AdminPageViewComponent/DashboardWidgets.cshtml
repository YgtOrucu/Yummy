@model ResultStatisticalDataDto
<div class="row">
    <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6 col-xs-12">
        <div class="card">
            <div class="card-statistic-4">
                <div class="row w-100 p-3 align-items-center">
                    <div class="col-9">
                        <div class="card-content">
                            <h5 class="font-14">Rezervasyon</h5>
                            <h2 class="mb-1 font-18">@Model.TotalReservation</h2>
                            <p class="mb-0 text-small"><span style="color: #6777ef;">Toplam</span> Rezerveler</p>
                        </div>
                    </div>
                    <div class="col-3 text-right">
                        <i class="fas fa-calendar-alt font-26" style="color: #6777ef;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6 col-xs-12">
        <div class="card">
            <div class="card-statistic-4">
                <div class="row w-100 p-3 align-items-center">
                    <div class="col-9">
                        <div class="card-content">
                            <h5 class="font-14">Müşteriler</h5>
                            <h2 class="mb-1 font-18">@Model.TotalCustomer</h2>
                            <p class="mb-0 text-small"><span style="color: #007bff;">Mutlu</span> Üyeler</p>
                        </div>
                    </div>
                    <div class="col-3 text-right">
                        <i class="fas fa-users font-26" style="color: #007bff;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6 col-xs-12">
        <div class="card">
            <div class="card-statistic-4">
                <div class="row w-100 p-3 align-items-center">
                    <div class="col-9">
                        <div class="card-content">
                            <h5 class="font-14">Ürünler</h5>
                            <h2 class="mb-1 font-18">@Model.TotalProduct</h2>
                            <p class="mb-0 text-small"><span class="col-blue">Menü</span> Kalemi</p>
                        </div>
                    </div>
                    <div class="col-3 text-right">
                        <i class="fas fa-utensils font-26 text-info"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6 col-xs-12">
        <div class="card">
            <div class="card-statistic-4">
                <div class="row w-100 p-3 align-items-center">
                    <div class="col-9">
                        <div class="card-content">
                            <h5 class="font-14">Rezervasyonlar</h5>
                            <h2 class="mb-1 font-18">@Model.NewReservationCount</h2>
                            <p class="mb-0 text-small"><span style="color: #e83e8c;">Yeni</span> Rezerveler</p>
                        </div>
                    </div>
                    <div class="col-3 text-right">
                        <i class="fas fa-map-marker-alt font-26" style="color: #e83e8c;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6 col-xs-12">
