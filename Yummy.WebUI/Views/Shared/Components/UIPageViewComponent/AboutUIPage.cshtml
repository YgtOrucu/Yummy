@model List<ResultAboutDto>

<section id="about" class="about section">
    <div class="container section-title" data-aos="fade-up">
        <h2>Hakkımızda<br></h2>
        <p><span>Daha Fazlası</span> <span class="description-title">Hakkımızda</span></p>
    </div>

    <div class="container">
        @foreach (var item in Model)
        {
            <div class="row gy-4">
                <div class="col-lg-7" data-aos="fade-up" data-aos-delay="100">
                    <img src="@(item.ImageUrl)" class="img-fluid mb-4" alt="">
                    <div class="book-a-table">
                        <h3>Book a Table</h3>
                        <p>@(item.ReservationNumber)</p>
                    </div>
                </div>
                <div class="col-lg-5" data-aos="fade-up" data-aos-delay="250">
                    <div class="content ps-0 ps-lg-5">
                        <p class="fst-italic">
                           @(item.Title)
                        </p>
                        <ul>
                            <li><i class="bi bi-check-circle-fill"></i> <span>@(item.ListDescription1)</span></li>
                            <li><i class="bi bi-check-circle-fill"></i> <span>@(item.ListDescription2)</span></li>
                            <li><i class="bi bi-check-circle-fill"></i> <span>@(item.ListDescription3)</span></li>
                        </ul>
                        <p>
                           @item.Description
                        </p>

                        <div class="position-relative mt-4">
                            <img src="@(item.VideoCoverImageUrl)" class="img-fluid" alt="">
                            <a href="@(item.VideoUrl)" class="glightbox pulsating-play-btn"></a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>