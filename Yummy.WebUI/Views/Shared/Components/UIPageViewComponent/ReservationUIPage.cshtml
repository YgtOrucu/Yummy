@model CreateReservationDto

<section id="book-a-table" class="book-a-table section">
    <div class="container section-title" data-aos="fade-up">
        <h2>Masa Rezervasyonu</h2>
        <p><span>Bizimle</span> <span class="description-title">Yerinizi Ayırtın<br></span></p>
    </div>

    <div class="container">
        <div class="row g-0" data-aos="fade-up" data-aos-delay="100">
            <div class="col-lg-4 reservation-img" style="background-image: url(/images/rezervation.png);"></div>

            <div class="col-lg-8 d-flex align-items-center reservation-form-bg" data-aos="fade-up" data-aos-delay="200">
                <form asp-controller="Reservation" asp-action="CreateReservation" method="post" class="php-email-form">
                    <div class="row gy-4">
                        <div class="col-lg-4 col-md-6">
                            <input type="text" asp-for="Name" class="form-control" placeholder="Adınız Soyadınız" required="">
                        </div>
                        <div class="col-lg-4 col-md-6">
                            <input type="email" asp-for="Email" class="form-control" placeholder="E-posta Adresiniz" required="">
                        </div>
                        <div class="col-lg-4 col-md-6">
                            <input type="text" asp-for="Phone" class="form-control"  placeholder="Telefon Numaranız" required="">
                        </div>
                        <div class="col-lg-4 col-md-6">
                            <input type="date" asp-for="ReservationDate" class="form-control" placeholder="Tarih" required="">
                        </div>
                        <div class="col-lg-4 col-md-6">
                            <input type="time" asp-for="ReservationTime" class="form-control" placeholder="Saat" required="">
                        </div>
                        <div class="col-lg-4 col-md-6">
                            <input type="number" asp-for="PeopleCount" class="form-control"  placeholder="Kişi Sayısı" required="">
                        </div>
                    </div>

                    <div class="form-group mt-3">
                        <textarea class="form-control" asp-for="Message" rows="5" placeholder="Mesajınız (Opsiyonel)"></textarea>
                    </div>

                    <div class="text-center mt-3">
                        <div class="loading">Yükleniyor</div>
                        <div class="error-message"></div>
                        <div class="sent-message">Rezervasyon talebiniz gönderildi. Onaylamak için sizi arayacağız veya e-posta göndereceğiz. Teşekkürler!</div>
                        <button type="submit">Masa Ayırt</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
