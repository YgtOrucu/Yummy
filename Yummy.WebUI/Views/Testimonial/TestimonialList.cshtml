@model List<ResultTestimonialDto>

@{
    ViewData["Title"] = "TestimonialList";
    Layout = "~/Views/AdminLayout/AdminLayout.cshtml";
}


<div class="col-12 col-md-12 col-lg-12">
    <div class="card">
        <div class="card-body">
            <div class="section-title">Yorumlar</div>
            <div class="table-responsive">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th scope="col">İsim Soyisim</th>
                            <th scope="col">Başlık</th>
                            <th scope="col">Yorum</th>
                            <th scope="col">Rating</th>
                            <th scope="col">IconUrl</th>
                            <th scope="col">Sil</th>
                            <th scope="col">Güncele</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td style="align-content:center">@item.Name</td>
                                <td style="align-content:center">@item.Title</td>
                                <td style="align-content:center">@(item.Comment.Length < 15 ? item.Comment : item.Comment.Substring(0, 15) + "...")</td>
                                <td style="align-content:center">@item.Rating</td>
                                <td>
                                    <img alt="Bakery item thumbnail"
                                         src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/default-150x150.png" : item.ImageUrl)"
                                         style="width: 3rem;height: 3rem;border-radius: 9999px;object-fit: cover;margin-left: auto;margin-right: auto;border: 2px solid #f1f5f9;" />
                                </td>
                                <td style="align-content:center"><a asp-controller="Testimonial" asp-action="TestimonialDelete" asp-route-id="@item.TestimonialId" class="btn btn-danger btn-sm">Sil</a></td>
                                <td style="align-content:center"><a asp-controller="Testimonial" asp-action="TestimonialUpdate" asp-route-id="@item.TestimonialId" class="btn btn-success btn-sm">Güncelle</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
                <a asp-controller="Testimonial" asp-action="TestimonialCreate" class="btn btn-primary btn-sm">Ekle</a>
            </div>
        </div>
    </div>
</div>


