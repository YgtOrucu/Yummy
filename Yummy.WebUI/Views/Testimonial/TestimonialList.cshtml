@model List<ResultTestimonialDto>

@{
    ViewData["Title"] = "TestimonialList";
    Layout = "~/Views/AdminLayout/AdminLayout.cshtml";
}
<div class="row">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-header d-flex justify-content-between align-items-center bg-white">
                <h4 class="text-dark font-weight-bold m-0"><i class="fas fa-comments mr-2"></i>Müşteri Yorumları</h4>
                <a asp-controller="Testimonial" asp-action="TestimonialCreate" class="btn btn-primary btn-round">Yeni Yorum</a>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="pl-4">Müşteri</th>
                            <th>Unvan</th>
                            <th>Yorum</th>
                            <th class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="pl-4 d-flex align-items-center">
                                    <img src="@item.ImageUrl" class="rounded-circle mr-3 shadow-sm" width="40" height="40" style="object-fit:cover;">
                                    <span class="font-weight-bold">@item.Name</span>
                                </td>
                                <td><span class="badge badge-light">@item.Title</span></td>
                                <td class="small">"@item.Comment.Substring(0, Math.Min(item.Comment.Length, 40))..."</td>
                                <td class="text-center">
                                    <a asp-controller="Testimonial" asp-action="TestimonialUpdate" asp-route-id="@item.TestimonialId" class="btn btn-sm btn-outline-info"><i class="fas fa-edit"></i></a>
                                    <a asp-controller="Testimonial" asp-action="TestimonialDelete" asp-route-id="@item.TestimonialId" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>