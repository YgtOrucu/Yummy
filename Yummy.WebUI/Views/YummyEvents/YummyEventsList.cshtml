@model List<ResultYummyEventDto>

@{
    ViewData["Title"] = "YummyEventsList";
    Layout = "~/Views/AdminLayout/AdminLayout.cshtml";
}
<div class="row">
    <div class="col-12 col-md-12 col-lg-12">
        <div class="card">
            <div class="card-body">
                <div class="section-title">Eventler</div>
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th scope="col">Title</th>
                                <th scope="col">Description</th>
                                <th scope="col">ImageUrl</th>
                                <th scope="col">Price</th>
                                <th scope="col">Sil</th>
                                <th scope="col">Güncele</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Title</td>
                                    <td>@(item.Description.Length < 20 ? item.Description : item.Description.Substring(0, 20) + "...")</td>
                                    <td>
                                        <img alt="Bakery item thumbnail"
                                             src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/default-150x150.png" : item.ImageUrl)"
                                             style="width: 3rem;height: 3rem;border-radius: 9999px;object-fit: cover;margin-left: auto;margin-right: auto;border: 2px solid #f1f5f9;" />
                                    </td>
                                    <td>@(item.Price.ToString("N2") + "₺")</td>
                                    <td><a asp-controller="YummyEvents" asp-action="YummyEventsDelete" asp-route-id="@item.YummyEventsId" class="btn btn-danger btn-sm">Sil</a></td>
                                    <td><a asp-controller="YummyEvents" asp-action="YummyEventsUpdate" asp-route-id="@item.YummyEventsId" class="btn btn-success btn-sm">Güncelle</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <a asp-controller="YummyEvents" asp-action="YummyEventsCreate" class="btn btn-primary btn-sm">Ekle</a>
                </div>
            </div>
        </div>
    </div>
</div>
