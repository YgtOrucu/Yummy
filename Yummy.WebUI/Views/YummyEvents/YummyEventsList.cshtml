@model List<ResultYummyEventDto>

@{
    ViewData["Title"] = "YummyEventsList";
    Layout = "~/Views/AdminLayout/AdminLayout.cshtml";
}
<div class="row">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-header d-flex justify-content-between align-items-center bg-white">
                <h4 class="text-dark font-weight-bold m-0"><i class="fas fa-glass-cheers mr-2"></i>Etkinlik Yönetimi</h4>
                <a asp-controller="YummyEvents" asp-action="YummyEventsCreate" class="btn btn-primary btn-round">Etkinlik Ekle</a>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="bg-light text-center">
                        <tr>
                            <th class="text-left pl-4">Etkinlik Adı</th>
                            <th>Fiyat</th>
                            <th>Güncelle / Sil</th>
                        </tr>
                    </thead>
                    <tbody class="text-center">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="pl-4 d-flex align-items-center">
                                    <img src="@item.ImageUrl" class="rounded-circle mr-3" width="45" height="45" style="object-fit: cover;">
                                    <span class="font-weight-bold">@item.Title</span>
                                </td>
                                <td><span class="text-success font-weight-bold">@item.Price.ToString("C2")</span></td>
                                <td>
                                    <a asp-controller="YummyEvents" asp-action="YummyEventsUpdate" asp-route-id="@item.YummyEventsId" class="btn btn-sm btn-outline-info"><i class="fas fa-sync"></i></a>
                                    <a asp-controller="YummyEvents" asp-action="YummyEventsDelete" asp-route-id="@item.YummyEventsId" class="btn btn-sm btn-outline-danger ml-1"><i class="fas fa-trash"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
